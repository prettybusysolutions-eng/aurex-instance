{
  "id": "thread-context",
  "name": "Thread Context",
  "description": "Persist per-topic thread state and inject isolated thread context during prompt building.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabledForChannels": {
        "type": "array",
        "items": { "type": "string" }
      },
      "maxMessages": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20
      },
      "includeExtractionNotes": {
        "type": "boolean"
      }
    }
  }
}
