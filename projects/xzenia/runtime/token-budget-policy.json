{
  "version": 1,
  "objective": "Prevent silent failure, truncation, and waste during long generations by forcing chunking, checkpointing, and budget-aware continuation.",
  "rules": {
    "checkpoint_before_long_output": true,
    "checkpoint_threshold_chars": 3500,
    "soft_chunk_target_chars": 2200,
    "hard_chunk_limit_chars": 3200,
    "reserve_for_wrapup_chars": 600,
    "prefer_status_over_repetition": true,
    "compress_when_restate_ratio_exceeds": 0.35,
    "write_state_before_multistep_generation": true
  },
  "status_language": [
    "done and verified",
    "attempted and failed",
    "blocked",
    "not yet executed"
  ]
}
